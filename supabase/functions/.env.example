# Copie para .env e preencha. Não commitar .env.
# Depois: supabase secrets set --env-file supabase/functions/.env
# Ou configure no Dashboard: Project Settings → Edge Functions → Secrets

# --- Stripe (checkout + webhook) ---
# Chave secreta da API (sk_test_... / sk_live_...)
# STRIPE_SECRET_KEY=
# Signing secret do endpoint de webhook (whsec_...)
# STRIPE_WEBHOOK_SECRET=
# Opcional: versão da API (default = mesma do stripe-node no package.json). Ver docs/STRIPE_INTEGRACAO.md
# STRIPE_API_VERSION=
# Guia: docs/STRIPE_INTEGRACAO.md

# --- Evolution API (WhatsApp) ---
# URL base da Evolution (sem barra no final). Ex.: https://evolution.seudominio.com
EVOLUTION_API_BASE_URL=
# API Key da Evolution (header apikey nas chamadas)
EVOLUTION_API_KEY=
# Evolution API v2 não permite configurar headers no webhook — deixe vazio.
# Só defina se usar Evolution v1 ou cliente que envie x-webhook-signature.
# EVOLUTION_WEBHOOK_SECRET=

# Na Evolution: configurar apenas a URL do webhook (sem header):
# https://<PROJECT_REF>.supabase.co/functions/v1/whatsapp-webhook
# Ver docs/EVOLUTION_INTEGRACAO.md.

# --- n8n (ingress: Evolution → n8n) ---
# Produção (usado quando STRATOSBOT_ENV não é "development")
N8N_INGRESS_WEBHOOK_URL=https://webhook.stratostech.com.br/webhook/stratosbotsaas
# Só desenvolvimento (usado quando STRATOSBOT_ENV=development)
N8N_INGRESS_WEBHOOK_URL_TEST=https://n8n.stratostech.com.br/webhook-test/stratosbotsaas
# Opcional: header x-api-key nas requisições ao webhook de ingress
# N8N_INGRESS_API_KEY=

# production = usa N8N_INGRESS_WEBHOOK_URL; development = usa N8N_INGRESS_WEBHOOK_URL_TEST
STRATOSBOT_ENV=production

# --- n8n (publish: aviso de agente publicado) ---
# N8N_PUBLISH_WEBHOOK_URL=
# N8N_PUBLISH_API_KEY=
